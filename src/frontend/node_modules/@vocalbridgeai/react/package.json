{
  "name": "@vocalbridgeai/react",
  "version": "0.1.1",
  "description": "React bindings for Vocal Bridge Voice Agent SDK",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "peerDependencies": {
    "@vocalbridgeai/sdk": ">=0.1.0",
    "react": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/vocalbridgeai/sdk.git",
    "directory": "packages/react"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "vocal-bridge",
    "voice-agent",
    "react",
    "hooks"
  ]
}
